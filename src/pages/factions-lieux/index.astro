---
import Base from '~/layouts/Base.astro';
import { getFactionEntries, prepareLore, wikiSlug } from '~/lib/data';
import LoreEntry from '~/components/LoreEntry.astro';

const entries = await getFactionEntries();
const prepared = await Promise.all(
  entries.map(async ({ entry, subtype }) => {
    const p = await prepareLore(entry);
    return { ...p, subtype };
  })
);

const total = prepared.length;
const counts = {
  all: total,
  secte: prepared.filter(p => p.subtype === 'secte').length,
  clan: prepared.filter(p => p.subtype === 'clan').length,
  lieu: prepared.filter(p => p.subtype === 'lieu').length,
};
---

<Base title="Factions & Lieux" active="factions">
  <header class="page-header">
    <h1 class="page-title">Factions & Lieux</h1>
    <p class="page-intro">
      {total} fiches — sectes, clans et lieux de <em>Renegade Immortel</em>.
    </p>
  </header>

  <nav class="filter-bar" aria-label="Filtrer par type">
    <button type="button" class="filter-btn is-active" data-filter="all">
      Tous <span class="filter-count">{counts.all}</span>
    </button>
    <button type="button" class="filter-btn" data-filter="secte">
      Sectes <span class="filter-count">{counts.secte}</span>
    </button>
    <button type="button" class="filter-btn" data-filter="clan">
      Clans <span class="filter-count">{counts.clan}</span>
    </button>
    <button type="button" class="filter-btn" data-filter="lieu">
      Lieux <span class="filter-count">{counts.lieu}</span>
    </button>
  </nav>

  <div class="lore-grid" id="faction-grid">
    {prepared.map(p => (
      <div class="lore-card-wrap" data-subtype={p.subtype}>
        <div class="subtype-badge" data-subtype={p.subtype}>
          {p.subtype === 'secte' ? 'Secte' : p.subtype === 'clan' ? 'Clan' : 'Lieu'}
        </div>
        <LoreEntry entry={p} />
      </div>
    ))}
  </div>

  <dialog id="lore-modal" class="lore-modal">
    <div class="lore-modal-inner">
      <button class="lore-modal-close" aria-label="Fermer" id="lore-modal-close">✕</button>
      <div class="lore-modal-header">
        <div id="lore-modal-img-wrap"></div>
        <div class="lore-modal-titles">
          <h2 id="lore-modal-name"></h2>
          <p id="lore-modal-cats"></p>
          <a id="lore-modal-source" href="#" target="_blank" rel="noopener" class="lore-modal-source">
            Source : Fandom Wiki ↗
          </a>
        </div>
      </div>
      <div class="lore-modal-body" id="lore-modal-body"></div>
    </div>
  </dialog>
</Base>

<script is:inline>
  (() => {
    const grid = document.getElementById('faction-grid');
    const dialog = document.getElementById('lore-modal');
    const closeBtn = document.getElementById('lore-modal-close');
    if (!grid || !dialog) return;

    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.lore-card-wrap');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        filterBtns.forEach(b => b.classList.toggle('is-active', b === btn));
        cards.forEach(c => {
          c.style.display = (filter === 'all' || c.dataset.subtype === filter) ? '' : 'none';
        });
      });
    });

    const nameEl = document.getElementById('lore-modal-name');
    const catsEl = document.getElementById('lore-modal-cats');
    const imgWrap = document.getElementById('lore-modal-img-wrap');
    const bodyEl = document.getElementById('lore-modal-body');
    const sourceEl = document.getElementById('lore-modal-source');

    grid.addEventListener('click', (e) => {
      const card = e.target.closest('.lore-card');
      if (!card) return;
      const slug = card.dataset.slug;
      const tpl = document.querySelector(`template[data-lore="${slug}"]`);
      if (!tpl) return;

      nameEl.textContent = tpl.dataset.name || '';
      catsEl.textContent = tpl.dataset.cats || '';

      const img = tpl.dataset.image;
      imgWrap.innerHTML = img
        ? `<img src="${img}" alt="${tpl.dataset.name || ''}" class="lore-modal-img" />`
        : '';

      const url = tpl.dataset.url;
      if (url) {
        sourceEl.href = url;
        sourceEl.style.display = '';
      } else {
        sourceEl.style.display = 'none';
      }

      bodyEl.innerHTML = '';
      bodyEl.appendChild(tpl.content.cloneNode(true));

      dialog.showModal();
      document.body.style.overflow = 'hidden';
    });

    function closeModal() {
      dialog.close();
      document.body.style.overflow = '';
    }
    closeBtn.addEventListener('click', closeModal);
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeModal();
    });
    dialog.addEventListener('cancel', () => {
      document.body.style.overflow = '';
    });
  })();
</script>

<style>
  .page-header { padding: 24px 0 24px; text-align: center; }
  .page-title {
    font-family: 'Cinzel', serif; font-size: 32px; font-weight: 600;
    color: var(--ink-1); margin: 0 0 8px; letter-spacing: .05em;
  }
  .page-intro {
    font-family: 'Cormorant Garamond', serif; font-size: 18px; font-style: italic;
    color: var(--ink-3); margin: 0;
  }

  .filter-bar {
    display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;
    padding: 0 0 32px;
  }
  .filter-btn {
    font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .18em;
    text-transform: uppercase; padding: 10px 18px;
    border: 1px solid var(--line); border-radius: var(--r-md);
    background: var(--bg-1); color: var(--ink-3); cursor: pointer;
    transition: color .2s, border-color .2s, background .2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .filter-btn:hover { color: var(--ink-1); border-color: var(--gold-dim); }
  .filter-btn.is-active {
    color: var(--crimson-2); border-color: var(--crimson-dim);
    background: rgba(179, 38, 30, .08);
  }
  .filter-count {
    font-size: 9px; padding: 2px 6px; border-radius: 8px;
    background: var(--bg-3); color: var(--ink-4);
  }
  .filter-btn.is-active .filter-count { background: var(--crimson-dim); color: var(--ink-1); }

  .lore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 16px; padding-bottom: 48px;
  }
  .lore-card-wrap { position: relative; }
  .subtype-badge {
    position: absolute; top: 8px; right: 8px; z-index: 2;
    font-family: 'Cinzel', serif; font-size: 8px; letter-spacing: .15em;
    text-transform: uppercase; padding: 3px 7px; border-radius: 8px;
    border: 1px solid; backdrop-filter: blur(4px);
  }
  .subtype-badge[data-subtype="secte"] {
    color: #b8a0d0; border-color: rgba(184, 160, 208, .4);
    background: rgba(40, 30, 60, .7);
  }
  .subtype-badge[data-subtype="clan"] {
    color: #d0a060; border-color: rgba(208, 160, 96, .4);
    background: rgba(50, 35, 20, .7);
  }
  .subtype-badge[data-subtype="lieu"] {
    color: #80c0a0; border-color: rgba(128, 192, 160, .4);
    background: rgba(20, 40, 30, .7);
  }

  .lore-modal {
    max-width: 800px; width: 90vw; max-height: 85vh;
    border: 1px solid var(--line); border-radius: var(--r-lg);
    background: var(--bg-1); color: var(--ink-1);
    padding: 0;
  }
  .lore-modal::backdrop {
    background: rgba(5, 4, 10, .8);
    backdrop-filter: blur(4px);
  }
  .lore-modal-inner {
    position: relative; padding: 32px; overflow-y: auto;
    max-height: 85vh;
  }
  .lore-modal-close {
    position: absolute; top: 16px; right: 16px;
    width: 32px; height: 32px; border-radius: 50%;
    border: 1px solid var(--line); background: var(--bg-2);
    color: var(--ink-3); cursor: pointer; font-size: 14px;
    display: flex; align-items: center; justify-content: center;
    transition: color .2s, border-color .2s;
  }
  .lore-modal-close:hover { color: var(--ink-1); border-color: var(--crimson-dim); }
  .lore-modal-header {
    display: flex; gap: 20px; margin-bottom: 24px;
    padding-bottom: 20px; border-bottom: 1px solid var(--line);
  }
  .lore-modal-img {
    width: 80px; height: 80px; border-radius: 50%; object-fit: cover;
    border: 2px solid var(--line); flex-shrink: 0;
  }
  .lore-modal-titles { min-width: 0; }
  .lore-modal-titles h2 {
    font-family: 'Cinzel', serif; font-size: 22px; font-weight: 600;
    color: var(--ink-1); margin: 0 0 4px; letter-spacing: .03em;
  }
  .lore-modal-titles p {
    font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .15em;
    text-transform: uppercase; color: var(--ink-4); margin: 0 0 8px;
  }
  .lore-modal-source {
    font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: .1em;
    color: var(--crimson-2); text-decoration: none;
  }
  .lore-modal-source:hover { text-decoration: underline; }
  .lore-modal-body {
    font-family: 'Noto Serif', Georgia, serif;
    font-size: 15px; line-height: 1.8; color: var(--ink-1);
  }
  .lore-modal-body :global(p) { margin: 0 0 1em; }
  .lore-modal-body :global(h2) {
    font-family: 'Cinzel', serif; font-size: 18px; color: var(--gold);
    margin: 1.5em 0 .6em; letter-spacing: .03em;
  }
  .lore-modal-body :global(h3) {
    font-family: 'Cinzel', serif; font-size: 15px; color: var(--gold);
    margin: 1.2em 0 .5em; letter-spacing: .03em;
  }
  .lore-modal-body :global(img) { max-width: 100%; border-radius: var(--r-md); margin: 1em 0; }
  .lore-modal-body :global(blockquote) {
    border-left: 3px solid var(--crimson-dim);
    padding-left: 16px; color: var(--ink-3); font-style: italic;
    margin: 1em 0;
  }
  .lore-modal-body :global(a) { color: var(--crimson-2); }
  .lore-modal-body :global(strong) { color: var(--ink-1); }

  @media (max-width: 640px) {
    .lore-modal-header { flex-direction: column; gap: 12px; }
    .lore-modal-inner { padding: 20px 16px; }
    .lore-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; }
    .filter-btn { padding: 8px 12px; font-size: 9px; }
  }
</style>
