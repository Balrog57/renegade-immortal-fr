---
import Base from '~/layouts/Base.astro';
import { getChaptersSorted, chapterSlug } from '~/lib/data';

const base = import.meta.env.BASE_URL;
const chapters = await getChaptersSorted();
---

<Base title="Accueil" active="home">
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="hero-subtitle">仙逆 · Xian Ni</p>
      <h1 class="hero-title">Renegade Immortel</h1>
      <p class="hero-tagline">L'odyssée d'un jeune orphelin devenu démon, forgeant son destin entre ciel et terre.</p>
      <div class="hero-cta">
        <a href={`${base}lecture/${chapterSlug(chapters[0])}/`} class="btn btn-primary">
          Commencer la lecture
        </a>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="stat">
      <span class="stat-num">2 088</span>
      <span class="stat-label">Chapitres</span>
    </div>
    <div class="stat">
      <span class="stat-num">13</span>
      <span class="stat-label">Tomes</span>
    </div>
    <div class="stat">
      <span class="stat-num">100 000+</span>
      <span class="stat-label">Ventes / volume</span>
    </div>
  </section>

  <section class="about">
    <header class="about-header">
      <h2 class="about-title">L'œuvre</h2>
      <p class="about-subtitle">仙逆 · Xian Ni — Un monument du xianxia moderne</p>
    </header>

    <div class="about-grid">
      <article class="about-block">
        <h3>Synopsis</h3>
        <p>
          <em>Renegade Immortel</em> suit Wang Lin, un jeune garçon intelligent mais au talent médiocre, qui s'engage sur la voie de la cultivation. Entre sectes qui s'effondrent, clans ancestraux et guerres entre Immortels, sa route n'est jamais droite. Il tue pour protéger ce qu'il aime, trahit pour survivre, et attend pendant des siècles ce que d'autres ont oublié — jusqu'à devenir l'une des figures les plus redoutables du cosmos.
        </p>
        <h3>L'auteur</h3>
        <p>
          <strong>Er Gen</strong> (耳根) est un romancier chinois de webnovels, figure majeure du genre xianxia. <em>Renegade Immortel</em> est l'une de ses premières œuvres majeures, publiée sur Qidian.
        </p>
      </article>

      <article class="about-block">
        <h3>Publication</h3>
        <ul>
          <li>Publication en feuilleton sur <strong>Qidian</strong> (plateforme de China Literature) du 8 juin 2009 au 8 janvier 2012</li>
          <li>Version imprimée (août 2012) par la Maison d'Édition de l'Éducation du Yunnan</li>
          <li><strong>2 088 chapitres</strong>, environ 6,57 millions de caractères</li>
        </ul>
        <h3>Genre</h3>
        <p>
          <strong>Xianxia</strong> — roman de cultivation et d'immortels chinois. Univers complet : système de cultivation multi-étapes, niveaux de pouvoir, origines ancestrales, clans anciens, bêtes divines, géographie multi-continents.
        </p>
      </article>

      <article class="about-block">
        <h3>Adaptations</h3>
        <ul>
          <li><strong>Manhua</strong> (2012) — publié sur Youman et Bilibili Comics</li>
          <li><strong>Jeu mobile</strong> (2015) — sortie officielle</li>
          <li><strong>Série animée</strong> (25 sept. 2023) — studio BUILD DREAM, 180 épisodes ONA, diffusée sur Tencent Video, score 8,50/10 sur MyAnimeList</li>
          <li><strong>Films d'animation</strong> (2025) — <em>Bataille de l'Avènement Divin</em> (n°1 des ventes payantes Tencent Video), second film annoncé</li>
        </ul>
        <h3>Un best-seller</h3>
        <p>
          Plus de <strong>100 000 exemplaires vendus par volume</strong> en version imprimée. Sur Webnovel : 8,8 millions de vues, note 4,18/5. Sur NovelFrance : 5,0/5, série terminée. L'un des piliers de la bibliothèque Qidian et un monument du xianxia moderne.
        </p>
      </article>
    </div>

    <footer class="about-footer">
      <p>Sources : Baidu Baike · Webnovel · NovelFrance · Xian Ni Fandom Wiki · MyAnimeList</p>
    </footer>
  </section>
</Base>

<style>
.hero {
  position: relative;
  min-height: 480px;
  display: flex; align-items: center; justify-content: center;
  text-align: center;
  overflow: hidden;
  margin: -32px -24px 0;
}
.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse at 50% 20%, rgba(74, 110, 216, .12) 0%, transparent 60%),
    radial-gradient(ellipse at 30% 80%, rgba(179, 38, 30, .10) 0%, transparent 50%),
    linear-gradient(180deg, var(--bg-1) 0%, var(--bg-0) 100%);
}
.hero-bg::before {
  content: ''; position: absolute; inset: 0;
  background-image:
    radial-gradient(1px 1px at 20% 30%, rgba(236,232,223,.15), transparent),
    radial-gradient(1px 1px at 60% 70%, rgba(236,232,223,.10), transparent),
    radial-gradient(1px 1px at 80% 20%, rgba(200,164,74,.12), transparent),
    radial-gradient(1px 1px at 40% 80%, rgba(236,232,223,.08), transparent),
    radial-gradient(1px 1px at 90% 50%, rgba(200,164,74,.10), transparent);
  background-size: 250px 250px;
  animation: drift 60s linear infinite;
}
@keyframes drift {
  from { background-position: 0 0; }
  to { background-position: 250px 250px; }
}
.hero-content { position: relative; z-index: 1; padding: 80px 24px; max-width: 720px; }
.hero-subtitle {
  font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: .4em;
  color: var(--ink-4); margin: 0 0 12px;
}
.hero-title {
  font-family: 'Cinzel', serif; font-size: 52px; font-weight: 700;
  letter-spacing: .06em; color: var(--ink-1); margin: 0 0 16px;
  text-shadow: 0 0 40px rgba(200,164,74,.15);
}
.hero-tagline {
  font-family: 'Cormorant Garamond', serif; font-size: 20px; font-style: italic;
  color: var(--ink-3); margin: 0 0 32px; line-height: 1.6;
}
.hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.btn {
  font-family: 'Cinzel', serif; font-size: 12px; letter-spacing: .15em;
  text-transform: uppercase; padding: 14px 28px; border-radius: var(--r-md);
  text-decoration: none; transition: all .2s var(--ease); border: 1px solid transparent;
}
.btn-primary {
  background: linear-gradient(135deg, var(--crimson-dim), var(--crimson));
  color: #fff; border-color: var(--crimson);
  box-shadow: 0 0 20px rgba(179,38,30,.2);
}
.btn-primary:hover { box-shadow: 0 0 30px rgba(179,38,30,.35); transform: translateY(-1px); text-decoration: none; }

.stats {
  display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
  padding: 48px 0; border-bottom: 1px solid var(--line);
}
.stat { text-align: center; min-width: 120px; }
.stat-num {
  display: block; font-family: 'Cinzel', serif; font-size: 32px; font-weight: 600;
  color: var(--gold); letter-spacing: .03em;
}
.stat-label {
  display: block; font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .2em;
  text-transform: uppercase; color: var(--ink-3); margin-top: 4px;
}

.about { padding: 64px 0 32px; }
.about-header { text-align: center; margin-bottom: 48px; }
.about-title {
  font-family: 'Cinzel', serif; font-size: 28px; font-weight: 600;
  color: var(--ink-1); margin: 0 0 8px; letter-spacing: .04em;
}
.about-subtitle {
  font-family: 'Cormorant Garamond', serif; font-size: 18px; font-style: italic;
  color: var(--ink-3); margin: 0;
}
.about-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 24px;
}
.about-block {
  padding: 24px; border: 1px solid var(--line); border-radius: var(--r-lg);
  background: var(--bg-1);
}
.about-block h3 {
  font-family: 'Cinzel', serif; color: var(--gold);
  font-size: 12px; letter-spacing: .18em; text-transform: uppercase;
  margin: 0 0 12px;
}
.about-block h3:not(:first-child) { margin-top: 28px; }
.about-block p, .about-block ul {
  font-family: 'Noto Serif', serif; font-size: 14px; line-height: 1.7;
  color: var(--ink-2); margin: 0;
}
.about-block ul { padding-left: 18px; }
.about-block li { margin-bottom: 8px; }
.about-block li:last-child { margin-bottom: 0; }
.about-block strong { color: var(--ink-1); }
.about-block em { color: var(--ink-1); font-style: italic; }
.about-footer {
  text-align: center; margin-top: 32px;
  font-family: 'Cinzel', serif; font-size: 10px;
  letter-spacing: .15em; text-transform: uppercase; color: var(--ink-4);
}

@media (max-width: 640px) {
  .hero-title { font-size: 36px; }
  .hero-tagline { font-size: 16px; }
  .stats { gap: 8px; }
  .stat { min-width: 90px; }
  .stat-num { font-size: 24px; }
  .about-grid { grid-template-columns: 1fr; }
}
</style>
