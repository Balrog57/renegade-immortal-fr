---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getChaptersSorted, getLoreEntries, chapterSlug } from '~/lib/data';

const base = import.meta.env.BASE_URL;

const [chapters, books, wikiAll] = await Promise.all([
  getChaptersSorted(),
  getCollection('books'),
  getCollection('wiki'),
]);

const counts = {
  chapters: chapters.length,
  books: books.length,
  personnages: wikiAll.filter(e => e.data.type === 'personnage').length,
  lieux: wikiAll.filter(e => e.data.type === 'lieu').length,
  sectes: wikiAll.filter(e => e.data.type === 'secte').length,
  cultivation: wikiAll.filter(e => e.data.type === 'cultivation').length,
};

const latestChapters = chapters.slice(-6).reverse();

const featuredRaw = await getLoreEntries('personnage');
const featured = featuredRaw.slice(0, 6).map(e => ({
  slug: e.id.replace(/\.md$/, '').split('/').pop(),
  name: e.data.name,
  title: e.data.title,
  image: e.data.image || null,
  categories: (e.data.categories || []).slice(0, 2),
}));
---

<Base title="Accueil" active="home">
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="hero-subtitle">仙逆 · Xian Ni</p>
      <h1 class="hero-title">Renegade Immortal</h1>
      <p class="hero-tagline">L'odyssée d'un jeune orphelin devenu démon, forgeant son destin entre ciel et terre.</p>
      <div class="hero-cta">
        <a href={`${base}lecture/${chapterSlug(chapters[0])}/`} class="btn btn-primary">
          Commencer la lecture
        </a>
        <a href={`${base}personnages/`} class="btn btn-ghost">
          Explorer le wiki
        </a>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="stat">
      <span class="stat-num">{counts.chapters.toLocaleString('fr')}</span>
      <span class="stat-label">Chapitres</span>
    </div>
    <div class="stat">
      <span class="stat-num">{counts.books}</span>
      <span class="stat-label">Tomes</span>
    </div>
    <div class="stat">
      <span class="stat-num">{counts.personnages.toLocaleString('fr')}</span>
      <span class="stat-label">Personnages</span>
    </div>
    <div class="stat">
      <span class="stat-num">{counts.lieux}</span>
      <span class="stat-label">Lieux</span>
    </div>
    <div class="stat">
      <span class="stat-num">{counts.sectes}</span>
      <span class="stat-label">Sectes & Clans</span>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Derniers chapitres</h2>
      <a href={`${base}chapitres/`} class="section-link">Tous les chapitres →</a>
    </div>
    <div class="chapter-cards">
      {latestChapters.map(c => (
        <a href={`${base}lecture/${chapterSlug(c)}/`} class="chapter-card">
          <span class="chapter-card-num">{String(c.data.n).padStart(4, '0')}</span>
          <span class="chapter-card-title">{c.data.title}</span>
          <span class="chapter-card-book">Tome {c.data.book}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Personnages clés</h2>
      <a href={`${base}personnages/`} class="section-link">Tous les personnages →</a>
    </div>
    <div class="char-cards">
      {featured.map(c => (
        <a href={`${base}personnages/`} class="char-card">
          {c.image ? (
            <img src={c.image} alt={c.name} class="char-card-img" loading="lazy" />
          ) : (
            <div class="char-card-placeholder">{c.name.charAt(0)}</div>
          )}
          <span class="char-card-name">{c.name}</span>
          {c.categories.length > 0 && (
            <span class="char-card-tag">{c.categories[0]}</span>
          )}
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
.hero {
  position: relative;
  min-height: 480px;
  display: flex; align-items: center; justify-content: center;
  text-align: center;
  overflow: hidden;
  margin: -32px -24px 0;
}
.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse at 50% 20%, rgba(74, 110, 216, .12) 0%, transparent 60%),
    radial-gradient(ellipse at 30% 80%, rgba(179, 38, 30, .10) 0%, transparent 50%),
    linear-gradient(180deg, var(--bg-1) 0%, var(--bg-0) 100%);
}
.hero-bg::before {
  content: ''; position: absolute; inset: 0;
  background-image:
    radial-gradient(1px 1px at 20% 30%, rgba(236,232,223,.15), transparent),
    radial-gradient(1px 1px at 60% 70%, rgba(236,232,223,.10), transparent),
    radial-gradient(1px 1px at 80% 20%, rgba(200,164,74,.12), transparent),
    radial-gradient(1px 1px at 40% 80%, rgba(236,232,223,.08), transparent),
    radial-gradient(1px 1px at 90% 50%, rgba(200,164,74,.10), transparent);
  background-size: 250px 250px;
  animation: drift 60s linear infinite;
}
@keyframes drift {
  from { background-position: 0 0; }
  to { background-position: 250px 250px; }
}
.hero-content { position: relative; z-index: 1; padding: 80px 24px; max-width: 720px; }
.hero-subtitle {
  font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: .4em;
  color: var(--ink-4); margin: 0 0 12px;
}
.hero-title {
  font-family: 'Cinzel', serif; font-size: 52px; font-weight: 700;
  letter-spacing: .06em; color: var(--ink-1); margin: 0 0 16px;
  text-shadow: 0 0 40px rgba(200,164,74,.15);
}
.hero-tagline {
  font-family: 'Cormorant Garamond', serif; font-size: 20px; font-style: italic;
  color: var(--ink-3); margin: 0 0 32px; line-height: 1.6;
}
.hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.btn {
  font-family: 'Cinzel', serif; font-size: 12px; letter-spacing: .15em;
  text-transform: uppercase; padding: 14px 28px; border-radius: var(--r-md);
  text-decoration: none; transition: all .2s var(--ease); border: 1px solid transparent;
}
.btn-primary {
  background: linear-gradient(135deg, var(--crimson-dim), var(--crimson));
  color: #fff; border-color: var(--crimson);
  box-shadow: 0 0 20px rgba(179,38,30,.2);
}
.btn-primary:hover { box-shadow: 0 0 30px rgba(179,38,30,.35); transform: translateY(-1px); text-decoration: none; }
.btn-ghost {
  background: transparent; color: var(--ink-2); border-color: var(--line);
}
.btn-ghost:hover { color: var(--ink-1); border-color: var(--gold-dim); text-decoration: none; }

.stats {
  display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
  padding: 48px 0; border-bottom: 1px solid var(--line);
}
.stat { text-align: center; min-width: 100px; }
.stat-num {
  display: block; font-family: 'Cinzel', serif; font-size: 32px; font-weight: 600;
  color: var(--gold); letter-spacing: .03em;
}
.stat-label {
  display: block; font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .2em;
  text-transform: uppercase; color: var(--ink-3); margin-top: 4px;
}

.section { padding: 48px 0; }
.section-header {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 24px; gap: 16px;
}
.section-title {
  font-family: 'Cinzel', serif; font-size: 22px; font-weight: 600;
  color: var(--ink-1); letter-spacing: .04em; margin: 0;
}
.section-link {
  font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: .12em;
  text-transform: uppercase; color: var(--ink-3); text-decoration: none;
}
.section-link:hover { color: var(--gold); text-decoration: none; }

.chapter-cards {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
}
.chapter-card {
  display: flex; flex-direction: column; gap: 4px;
  padding: 16px; border: 1px solid var(--line); border-radius: var(--r-md);
  background: var(--bg-1); text-decoration: none;
  transition: border-color .2s, background .2s;
}
.chapter-card:hover { border-color: var(--crimson-dim); background: var(--bg-2); text-decoration: none; }
.chapter-card-num {
  font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: .15em;
  color: var(--crimson-2);
}
.chapter-card-title {
  font-family: 'Noto Serif', serif; font-size: 14px; color: var(--ink-1);
  line-height: 1.4;
}
.chapter-card-book {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .15em;
  text-transform: uppercase; color: var(--ink-4);
}

.char-cards {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 16px;
}
.char-card {
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  padding: 20px 12px; border: 1px solid var(--line); border-radius: var(--r-lg);
  background: var(--bg-1); text-decoration: none;
  transition: border-color .2s, transform .2s;
}
.char-card:hover { border-color: var(--gold-dim); transform: translateY(-2px); text-decoration: none; }
.char-card-img {
  width: 80px; height: 80px; border-radius: 50%; object-fit: cover;
  border: 2px solid var(--line);
}
.char-card-placeholder {
  width: 80px; height: 80px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Cinzel', serif; font-size: 28px; font-weight: 600;
  color: var(--ink-3); background: var(--bg-3); border: 2px solid var(--line);
}
.char-card-name {
  font-family: 'Cinzel', serif; font-size: 13px; color: var(--ink-1);
  text-align: center; letter-spacing: .03em;
}
.char-card-tag {
  font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: .15em;
  text-transform: uppercase; color: var(--ink-4);
}

@media (max-width: 640px) {
  .hero-title { font-size: 36px; }
  .hero-tagline { font-size: 16px; }
  .stats { gap: 8px; }
  .stat { min-width: 80px; }
  .stat-num { font-size: 24px; }
}
</style>
