---
import Base from '~/layouts/Base.astro';
import { render } from 'astro:content';
import { getBooksSorted } from '~/lib/data';

const base = import.meta.env.BASE_URL;
const books = await getBooksSorted();

const prepared = await Promise.all(
  books.map(async b => {
    const { Content } = await render(b);
    return { book: b.data.book, title: b.data.title, cover: b.data.cover, count: b.data.chaptersCount, rangeStart: b.data.rangeStart, rangeEnd: b.data.rangeEnd, Content };
  })
);
---

<Base title="Livres" active="livres">
  <header class="page-header">
    <h1 class="page-title">Livres</h1>
    <p class="page-intro">{books.length} tomes de l'œuvre originale.</p>
  </header>

  <div class="book-grid">
    {prepared.map(b => {
      const C = b.Content;
      return (
      <div class="book-card">
        {b.cover ? (
          <img src={b.cover} alt={`Tome ${b.book}`} class="book-cover" loading="lazy" />
        ) : (
          <div class="book-cover-fallback">{b.book}</div>
        )}
        <div class="book-info">
          <span class="book-num">Tome {b.book}</span>
          <h2 class="book-title">{b.title}</h2>
          <p class="book-meta">
            {b.count || '—'} chapitres
            {b.rangeStart && b.rangeEnd ? ` · n°${b.rangeStart}–${b.rangeEnd}` : ''}
          </p>
          <div class="book-body">
            <C />
          </div>
          <a href={`${base}chapitres/tome-${b.book}/`} class="book-link">Lire ce tome →</a>
        </div>
      </div>
      );
    })}
  </div>
</Base>

<style>
.page-header { padding: 24px 0 40px; text-align: center; }
.page-title {
  font-family: 'Cinzel', serif; font-size: 32px; font-weight: 600;
  color: var(--ink-1); margin: 0 0 8px; letter-spacing: .05em;
}
.page-intro {
  font-family: 'Cormorant Garamond', serif; font-size: 18px; font-style: italic;
  color: var(--ink-3); margin: 0;
}

.book-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 24px; padding-bottom: 40px;
}
.book-card {
  display: flex; gap: 20px;
  padding: 24px; border: 1px solid var(--line); border-radius: var(--r-lg);
  background: var(--bg-1);
}
.book-cover {
  width: 90px; height: 130px; object-fit: cover; border-radius: var(--r-md);
  flex-shrink: 0; border: 1px solid var(--line);
}
.book-cover-fallback {
  width: 90px; height: 130px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Cinzel', serif; font-size: 36px; font-weight: 600;
  color: var(--gold-dim); background: var(--bg-3);
  border: 1px solid var(--line); border-radius: var(--r-md);
}
.book-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
.book-num {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .2em;
  text-transform: uppercase; color: var(--crimson-2);
}
.book-title {
  font-family: 'Noto Serif', serif; font-size: 16px; font-weight: 600;
  color: var(--ink-1); margin: 0; line-height: 1.3;
}
.book-meta {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .1em;
  color: var(--ink-4); margin: 0 0 8px;
}
.book-body {
  font-family: 'Noto Serif', serif; font-size: 14px; line-height: 1.6;
  color: var(--ink-3); flex: 1;
}
.book-body :global(p) { margin: 0 0 .5em; }
.book-body :global(em) { color: var(--ink-2); }
.book-link {
  font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: .12em;
  text-transform: uppercase; color: var(--crimson-2); text-decoration: none;
  margin-top: 8px;
}
.book-link:hover { color: var(--gold); text-decoration: none; }

@media (max-width: 640px) {
  .book-card { flex-direction: column; align-items: center; text-align: center; }
}
</style>
