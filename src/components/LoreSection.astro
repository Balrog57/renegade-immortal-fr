---
import Base from '~/layouts/Base.astro';
import { getLoreEntries, prepareLore, loreSectionByType } from '~/lib/data';
import LoreEntry from '~/components/LoreEntry.astro';

interface Props {
  type: 'personnage' | 'lieu' | 'secte' | 'cultivation';
  active: string;
  heroSlug?: string;
}

const { type, active, heroSlug } = Astro.props;
const section = loreSectionByType(type);
const entries = await getLoreEntries(type);
const prepared = await Promise.all(entries.map(prepareLore));
const hero = heroSlug ? prepared.find(p => p.slug === heroSlug) : null;
const rest = hero ? prepared.filter(p => p.slug !== heroSlug) : prepared;
---

<Base title={section?.label ?? 'Wiki'} active={active}>
<div class="lore-container">
  <header class="page-header">
    <h1 class="page-title">{section?.label}</h1>
    <p class="page-intro">
      {prepared.length} {prepared.length > 1 ? (section?.singular + 's') : section?.singular}
      {type === 'personnage' || type === 'lieu' ? ' · mise en avant' : ''}
    </p>
  </header>

  {hero && (
    <a href="#" class="hero-card" data-slug={hero.slug} data-name={hero.name} data-cats={hero.categories.join(', ')} data-image={hero.image} data-url={hero.url}>
      <div class="hero-card-img-wrap">
        {hero.image
          ? <img src={hero.image} alt={hero.name} class="hero-card-img" />
          : <div class="hero-card-placeholder">{hero.name.charAt(0)}</div>}
      </div>
      <div class="hero-card-body">
        <p class="hero-card-tag">Personnage principal</p>
        <h2 class="hero-card-name">{hero.name}</h2>
        <p class="hero-card-title">{hero.title}</p>
        <p class="hero-card-cats">{hero.categories.join(' · ')}</p>
      </div>
    </a>
  )}

  <div class="lore-grid">
    {rest.map(p => <LoreEntry entry={p} />)}
  </div>

  {hero && (
    <template
      data-lore={hero.slug}
      data-name={hero.name}
      data-title={hero.title}
      data-image={hero.image || ''}
      data-cats={hero.categories.join(', ')}
      data-url={hero.url || ''}
    >
      <hero.Content />
    </template>
  )}
</div>

  <dialog id="lore-modal" class="lore-modal">
    <div class="lore-modal-inner">
      <button class="lore-modal-close" aria-label="Fermer" id="lore-modal-close">✕</button>
      <div class="lore-modal-header">
        <div id="lore-modal-img-wrap"></div>
        <div class="lore-modal-titles">
          <h2 id="lore-modal-name"></h2>
          <p id="lore-modal-cats"></p>
          <a id="lore-modal-source" href="#" target="_blank" rel="noopener" class="lore-modal-source">
            Source : Fandom Wiki ↗
          </a>
        </div>
      </div>
      <div class="lore-modal-body" id="lore-modal-body"></div>
    </div>
  </dialog>
</Base>

<script is:inline>
  (() => {
    const container = document.querySelector('.lore-container');
    const dialog = document.getElementById('lore-modal');
    const closeBtn = document.getElementById('lore-modal-close');
    if (!container || !dialog) return;

    const nameEl = document.getElementById('lore-modal-name');
    const catsEl = document.getElementById('lore-modal-cats');
    const imgWrap = document.getElementById('lore-modal-img-wrap');
    const bodyEl = document.getElementById('lore-modal-body');
    const sourceEl = document.getElementById('lore-modal-source');

    container.addEventListener('click', (e) => {
      const card = e.target.closest('.lore-card, .hero-card');
      if (!card) return;
      const slug = card.dataset.slug;
      const tpl = document.querySelector(`template[data-lore="${slug}"]`);
      if (!tpl) return;

      nameEl.textContent = tpl.dataset.name || '';
      catsEl.textContent = tpl.dataset.cats || '';

      const img = tpl.dataset.image;
      imgWrap.innerHTML = img
        ? `<img src="${img}" alt="${tpl.dataset.name || ''}" class="lore-modal-img" />`
        : '';

      const url = tpl.dataset.url;
      if (url) {
        sourceEl.href = url;
        sourceEl.style.display = '';
      } else {
        sourceEl.style.display = 'none';
      }

      bodyEl.innerHTML = '';
      bodyEl.appendChild(tpl.content.cloneNode(true));

      dialog.showModal();
      document.body.style.overflow = 'hidden';
    });

    function closeModal() {
      dialog.close();
      document.body.style.overflow = '';
    }

    closeBtn.addEventListener('click', closeModal);
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeModal();
    });
    dialog.addEventListener('cancel', () => {
      document.body.style.overflow = '';
    });
  })();
</script>

<style>
.page-header { padding: 24px 0 40px; text-align: center; }
.page-title {
  font-family: 'Cinzel', serif; font-size: 32px; font-weight: 600;
  color: var(--ink-1); margin: 0 0 8px; letter-spacing: .05em;
}
.page-intro {
  font-family: 'Cormorant Garamond', serif; font-size: 18px; font-style: italic;
  color: var(--ink-3); margin: 0;
}

.hero-card {
  display: flex; align-items: center; gap: 24px;
  padding: 24px; margin-bottom: 32px;
  border: 1px solid var(--line); border-radius: var(--r-lg);
  background: linear-gradient(135deg, var(--bg-2) 0%, var(--bg-1) 100%);
  cursor: pointer; text-decoration: none; color: inherit;
  transition: border-color .2s, transform .2s, box-shadow .2s;
}
.hero-card:hover {
  border-color: var(--gold-dim); transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, .3);
}
.hero-card-img-wrap { flex-shrink: 0; }
.hero-card-img {
  width: 120px; height: 120px; border-radius: 50%; object-fit: cover;
  border: 3px solid var(--line);
}
.hero-card-placeholder {
  width: 120px; height: 120px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Cinzel', serif; font-size: 40px; font-weight: 600;
  color: var(--ink-3); background: var(--bg-3); border: 3px solid var(--line);
}
.hero-card-body { flex: 1; min-width: 0; }
.hero-card-tag {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .2em;
  text-transform: uppercase; color: var(--crimson-2); margin: 0 0 8px;
}
.hero-card-name {
  font-family: 'Cinzel', serif; font-size: 28px; font-weight: 600;
  color: var(--ink-1); margin: 0 0 4px; letter-spacing: .03em;
}
.hero-card-title {
  font-family: 'Cormorant Garamond', serif; font-size: 18px;
  font-style: italic; color: var(--ink-3); margin: 0 0 12px;
}
.hero-card-cats {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .12em;
  text-transform: uppercase; color: var(--ink-4); margin: 0;
}

@media (max-width: 640px) {
  .hero-card { flex-direction: column; text-align: center; gap: 16px; }
  .hero-card-body { text-align: center; }
}

.lore-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 16px; padding-bottom: 40px;
}

.lore-card {
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  padding: 20px 12px; border: 1px solid var(--line); border-radius: var(--r-lg);
  background: var(--bg-1); cursor: pointer;
  transition: border-color .2s, transform .2s, background .2s;
}
.lore-card:hover { border-color: var(--gold-dim); transform: translateY(-2px); background: var(--bg-2); }
.lore-card-img {
  width: 80px; height: 80px; border-radius: 50%; object-fit: cover;
  border: 2px solid var(--line);
}
.lore-card-placeholder {
  width: 80px; height: 80px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Cinzel', serif; font-size: 28px; font-weight: 600;
  color: var(--ink-3); background: var(--bg-3); border: 2px solid var(--line);
}
.lore-card-name {
  font-family: 'Cinzel', serif; font-size: 13px; color: var(--ink-1);
  text-align: center; letter-spacing: .03em; line-height: 1.3;
}
.lore-card-cats {
  font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: .12em;
  text-transform: uppercase; color: var(--ink-4); text-align: center;
}

.lore-modal {
  max-width: 800px; width: 90vw; max-height: 85vh;
  border: 1px solid var(--line); border-radius: var(--r-lg);
  background: var(--bg-1); color: var(--ink-1);
  padding: 0;
}
.lore-modal::backdrop {
  background: rgba(5, 4, 10, .8);
  backdrop-filter: blur(4px);
}
.lore-modal-inner {
  position: relative; padding: 32px; overflow-y: auto;
  max-height: 85vh;
}
.lore-modal-close {
  position: absolute; top: 16px; right: 16px;
  width: 32px; height: 32px; border-radius: 50%;
  border: 1px solid var(--line); background: var(--bg-2);
  color: var(--ink-3); cursor: pointer; font-size: 14px;
  display: flex; align-items: center; justify-content: center;
  transition: color .2s, border-color .2s;
}
.lore-modal-close:hover { color: var(--ink-1); border-color: var(--crimson-dim); }

.lore-modal-header {
  display: flex; gap: 20px; margin-bottom: 24px;
  padding-bottom: 20px; border-bottom: 1px solid var(--line);
}
.lore-modal-img {
  width: 80px; height: 80px; border-radius: 50%; object-fit: cover;
  border: 2px solid var(--line); flex-shrink: 0;
}
.lore-modal-titles { min-width: 0; }
.lore-modal-titles h2 {
  font-family: 'Cinzel', serif; font-size: 22px; font-weight: 600;
  color: var(--ink-1); margin: 0 0 4px; letter-spacing: .03em;
}
.lore-modal-titles p {
  font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .15em;
  text-transform: uppercase; color: var(--ink-4); margin: 0 0 8px;
}
.lore-modal-source {
  font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: .1em;
  color: var(--crimson-2); text-decoration: none;
}
.lore-modal-source:hover { text-decoration: underline; }

.lore-modal-body {
  font-family: 'Noto Serif', Georgia, serif;
  font-size: 15px; line-height: 1.8; color: var(--ink-1);
}
.lore-modal-body :global(p) { margin: 0 0 1em; }
.lore-modal-body :global(h2) {
  font-family: 'Cinzel', serif; font-size: 18px; color: var(--gold);
  margin: 1.5em 0 .6em; letter-spacing: .03em;
}
.lore-modal-body :global(h3) {
  font-family: 'Cinzel', serif; font-size: 15px; color: var(--gold);
  margin: 1.2em 0 .5em; letter-spacing: .03em;
}
.lore-modal-body :global(img) { max-width: 100%; border-radius: var(--r-md); margin: 1em 0; }
.lore-modal-body :global(blockquote) {
  border-left: 3px solid var(--crimson-dim);
  padding-left: 16px; color: var(--ink-3); font-style: italic;
  margin: 1em 0;
}
.lore-modal-body :global(a) { color: var(--crimson-2); }
.lore-modal-body :global(strong) { color: var(--ink-1); }

@media (max-width: 640px) {
  .lore-modal-header { flex-direction: column; gap: 12px; }
  .lore-modal-inner { padding: 20px 16px; }
  .lore-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; }
}
</style>
