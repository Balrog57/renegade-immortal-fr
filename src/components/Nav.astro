---
const { title, active = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
const nav = [
  { key: 'home',        label: 'Accueil',           href: `${base}` },
  { key: 'chapitres',   label: 'Chapitres',         href: `${base}chapitres/` },
  { key: 'personnages', label: 'Personnages',       href: `${base}personnages/` },
  { key: 'cultivation', label: 'Cultivation',       href: `${base}cultivation/` },
  { key: 'sectes',      label: 'Sectes & Clans',    href: `${base}sectes-clans/` },
  { key: 'lieux',       label: 'Lieux',             href: `${base}lieux/` },
  { key: 'livres',      label: 'Livres',            href: `${base}livres/` },
];
---
<header class="nav">
  <div class="nav-inner">
    <a href={`${base}`} class="brand" aria-label="Renegade Immortel FR — accueil">
      <span class="dot" aria-hidden="true"></span>
      <span>Renegade Immortel</span>
      <small>· Xian Ni · 仙逆</small>
    </a>
    <button class="nav-burger" id="nav-burger" aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="nav-tabs" id="nav-tabs" role="navigation" aria-label="Sections principales">
      {nav.map(item => (
        <a href={item.href} class:list={["nav-tab", { 'is-active': active === item.key }]}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
.nav {
  position: sticky; top: 0; z-index: 50;
  background: rgba(8, 6, 15, .88);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--line);
}
.nav-inner {
  max-width: 1280px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 24px; gap: 24px;
}
.brand {
  display: inline-flex; align-items: baseline; gap: 8px;
  font-family: 'Cinzel', serif; font-weight: 600;
  color: var(--ink-1); text-decoration: none; letter-spacing: .05em;
  font-size: 14px;
}
.brand .dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, var(--gold) 0%, var(--crimson-dim) 70%);
  box-shadow: 0 0 10px rgba(200, 164, 74, .5);
  align-self: center;
}
.brand small { color: var(--ink-3); font-size: 10px; letter-spacing: .2em; }
.nav-tabs { display: flex; gap: 4px; flex-wrap: wrap; }
.nav-tab {
  font-family: 'Cinzel', serif; font-size: 10.5px; letter-spacing: .18em;
  text-transform: uppercase; color: var(--ink-3);
  padding: 8px 12px; border-radius: var(--r-md);
  transition: color .2s, background .2s;
  text-decoration: none; border: 1px solid transparent;
}
.nav-tab:hover { color: var(--ink-1); background: rgba(200, 164, 74, .06); text-decoration: none; }
.nav-tab.is-active { color: var(--crimson-2); border-color: var(--crimson-dim); background: rgba(179, 38, 30, .08); }
.nav-burger {
  display: none; background: transparent; border: 0;
  width: 32px; height: 24px; position: relative; cursor: pointer;
}
.nav-burger span {
  position: absolute; left: 0; right: 0; height: 2px; background: var(--ink-2);
  transition: transform .2s, opacity .2s;
}
.nav-burger span:nth-child(1) { top: 4px; }
.nav-burger span:nth-child(2) { top: 11px; }
.nav-burger span:nth-child(3) { top: 18px; }
.nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-burger.is-open span:nth-child(2) { opacity: 0; }
.nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

@media (max-width: 880px) {
  .nav-burger { display: block; }
  .nav-tabs {
    position: absolute; top: 100%; left: 0; right: 0;
    flex-direction: column; gap: 0;
    background: var(--bg-1); border-bottom: 1px solid var(--line);
    padding: 8px 0; display: none;
  }
  .nav-tabs.is-open { display: flex; }
  .nav-tab { padding: 12px 24px; border-radius: 0; border: 0; }
}
</style>

<script is:inline>
  (() => {
    const burger = document.getElementById('nav-burger');
    const tabs = document.getElementById('nav-tabs');
    if (!burger || !tabs) return;
    burger.addEventListener('click', () => {
      const open = tabs.classList.toggle('is-open');
      burger.classList.toggle('is-open', open);
      burger.setAttribute('aria-expanded', String(open));
    });
  })();
</script>