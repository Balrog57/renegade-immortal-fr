---
const base = import.meta.env.BASE_URL;
---
<footer class="site-footer">
  <div class="seal">Renegade Immortel FR</div>
  <div>
    Traduction communautaire non-officielle · Contenu via
    <a class="fandom-link" href="https://xian-ni.fandom.com/wiki/Xian_Ni_Wikia" target="_blank" rel="noopener">Xian Ni Fandom Wiki</a>
    (CC BY-SA) ·
    <a href={`${base}LICENSE.txt`} class="fandom-link">MIT/CC0</a>
  </div>
</footer>

<style>
.site-footer {
  margin-top: 80px;
  padding: 32px 24px;
  border-top: 1px solid var(--line);
  text-align: center;
  color: var(--ink-3);
  font-size: 12px;
  font-family: 'Cinzel', serif;
  letter-spacing: .15em;
}
.site-footer .seal {
  color: var(--crimson-2);
  margin-bottom: 6px;
  letter-spacing: .3em;
}
.site-footer a { color: var(--ink-2); }
</style>