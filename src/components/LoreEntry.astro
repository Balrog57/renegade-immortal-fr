---
import type { PreparedLore } from '~/lib/data';

interface Props {
  entry: PreparedLore;
}

const { entry } = Astro.props;
const C = entry.Content;
const initial = entry.name.charAt(0).toUpperCase();
const cats = entry.categories.join(', ');
---

<div class="lore-card" data-slug={entry.slug}>
  {entry.image ? (
    <img src={entry.image} alt={entry.name} class="lore-card-img" loading="lazy" />
  ) : (
    <div class="lore-card-placeholder">{initial}</div>
  )}
  <span class="lore-card-name">{entry.name}</span>
  {entry.categories.length > 0 && (
    <span class="lore-card-cats">{cats}</span>
  )}
</div>

<template
  data-lore={entry.slug}
  data-name={entry.name}
  data-title={entry.title}
  data-image={entry.image || ''}
  data-cats={cats}
  data-url={entry.url || ''}
>
  <C />
</template>
